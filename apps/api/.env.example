DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
PORT=3000

# JWT：生产环境务必使用长随机串
JWT_SECRET="replace-with-long-random-string"

# 微信小程序 AppID / AppSecret（勿提交真实密钥）
# 用于：拉取 access_token、调用 getuserphonenumber 换取手机号（手机号快捷登录），与 manifest.json 中 appid 一致
WECHAT_MINI_APPID=""
WECHAT_MINI_SECRET=""

# 其他手机号登录（验证码）开发调试码；留空则每次随机生成 6 位。
# 非生产环境会在 /auth/phone/send-code 响应中返回 testCode 便于联调。
SMS_LOGIN_TEST_CODE="123456"
